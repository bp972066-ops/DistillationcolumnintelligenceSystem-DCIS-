# ═══════════════════════════ RULE-BASED DIAGNOSIS ══════════════════════════
class RuleBasedDiagnostics:
    def diagnose(self, cond: ColumnConditions, symptoms_text: list) -> list:
        results = []
        sym_str = " ".join(symptoms_text).lower()

        rules = {
            "FLOODING": self._score_flooding,
            "WEEPING":  self._score_weeping,
            "FOAMING":  self._score_foaming,
            "ENTRAINMENT": self._score_entrainment,
            "FOULING":  self._score_fouling,
            "REBOILER_ISSUES": self._score_reboiler,
            "PRESSURE_CONTROL": self._score_pressure,
        }

        for name, fn in rules.items():
            score, matched = fn(cond, sym_str)
            if score >= 20:
                if score >= 60: sev, conf = "CRITICAL", "HIGH"
                elif score >= 35: sev, conf = "WARNING", "MEDIUM"
                else: sev, conf = "INFO", "LOW"
                p = PROBLEMS[name]
                results.append(DiagnosisResult(
                    problem=name, severity=sev, confidence=conf, score=score,
                    description=p["description"], symptoms_matched=matched,
                    root_causes=p["root_causes"],
                    corrective_actions=p["corrective_actions"],
                    preventive_measures=p["preventive_measures"],
                ))

        return sorted(results, key=lambda x: x.score, reverse=True)

    def _score_flooding(self, c, s):
        sc, m = 0, []
        if c.dp_tray and c.design_dp_per_tray:
            r = c.dp_tray / c.design_dp_per_tray
            if r > 1.5:   sc += 40; m.append(f"ΔP/tray = {c.dp_tray:.2f} kPa  ({r:.1f}× design — CRITICAL)")
            elif r > 1.2: sc += 20; m.append(f"ΔP/tray elevated = {c.dp_tray:.2f} kPa ({r:.1f}× design)")
        if c.sudden_pressure_spike: sc += 25; m.append("Sudden pressure spike confirmed")
        if c.product_off_spec:      sc += 10; m.append("Product quality off-spec")
        if c.vibration_observed:    sc += 10; m.append("Abnormal vibrations / knocking")
        if c.feed_rate and c.design_feed_rate and c.feed_rate > 1.1 * c.design_feed_rate:
            sc += 20; m.append(f"Feed {c.feed_rate:.0f} kg/h > 110% of design ({c.design_feed_rate:.0f})")
        if any(k in s for k in ["flood","liquid level drop","bottom level","pressure spike","knock"]):
            sc += 30; m.append("Keyword match — flooding symptoms in description")
        return sc, m

    def _score_weeping(self, c, s):
        sc, m = 0, []
        if c.dp_tray and c.design_dp_per_tray:
            r = c.dp_tray / c.design_dp_per_tray
            if r < 0.4:   sc += 40; m.append(f"ΔP/tray = {c.dp_tray:.2f} kPa — very low ({r:.1f}× design)")
            elif r < 0.6: sc += 20; m.append(f"ΔP/tray low = {c.dp_tray:.2f} kPa ({r:.1f}× design)")
        if c.feed_rate and c.design_feed_rate and c.feed_rate < 0.5 * c.design_feed_rate:
            sc += 30; m.append(f"Feed {c.feed_rate:.0f} < 50% design — turndown risk")
        if any(k in s for k in ["weep","low pressure","poor separation","both products","low throughput","turndown"]):
            sc += 35; m.append("Keyword match — weeping symptoms in description")
        return sc, m

    def _score_foaming(self, c, s):
        sc, m = 0, []
        if c.foaming_observed: sc += 50; m.append("Foaming directly observed/confirmed")
        if any(k in s for k in ["foam","erratic","fluctuat","surging","unstable","oscillat","froth"]):
            sc += 35; m.append("Keyword match — foaming/erratic behavior described")
        return sc, m

    def _score_entrainment(self, c, s):
        sc, m = 0, []
        if c.dp_tray and c.design_dp_per_tray:
            r = c.dp_tray / c.design_dp_per_tray
            if 1.1 < r < 1.5: sc += 25; m.append(f"ΔP/tray moderately high = {c.dp_tray:.2f} kPa")
        if any(k in s for k in ["entrain","carryover","distillate contam","heavy in overhead","top quality"]):
            sc += 40; m.append("Keyword match — entrainment described")
        if c.product_off_spec: sc += 10; m.append("Product off-spec (likely heavy in overhead)")
        return sc, m

    def _score_fouling(self, c, s):
        sc, m = 0, []
        if any(k in s for k in ["foul","gradual","scale","deposit","plugg","coke","build","reducing capacity","drift"]):
            sc += 45; m.append("Keyword match — gradual fouling symptoms described")
        if c.reboiler_duty and c.reboiler_duty > 110:
            sc += 15; m.append(f"Reboiler duty elevated = {c.reboiler_duty:.1f}%")
        return sc, m

    def _score_reboiler(self, c, s):
        sc, m = 0, []
        if c.bottom_temp and c.feed_temp and c.bottom_temp < c.feed_temp:
            sc += 30; m.append(f"Bottom temp ({c.bottom_temp}°C) < Feed temp ({c.feed_temp}°C) — abnormal")
        if any(k in s for k in ["reboiler","steam","heat duty","bottom temp low","no vapor","tube leak","contamination"]):
            sc += 40; m.append("Keyword match — reboiler issue described")
        return sc, m

    def _score_pressure(self, c, s):
        sc, m = 0, []
        if any(k in s for k in ["pressure control","condenser","non-condensable","vent","pressure high","pressure low","pcv","cooling water"]):
            sc += 40; m.append("Keyword match — pressure control symptoms described")
        if c.top_pressure and c.bottom_pressure and c.top_pressure > c.bottom_pressure:
            sc += 30; m.append("Top pressure > Bottom pressure — pressure inversion detected")
        return sc, m

# ═══════════════════════════ GEMINI AI INTEGRATION ═════════════════════════
def gemini_enhance(cond_dict: dict, results: list, symptoms: list) -> dict:
    """
    Call Gemini to produce an AI-enhanced narrative for each diagnosed fault.
    Returns a dict keyed by problem name with the AI text, or an empty dict on failure.
    """
    if not GEMINI_ENABLED or not GOOGLE_API_KEY:
        return {}

    faults_summary = [
        {"fault": r.problem, "severity": r.severity,
         "score": r.score, "triggers": r.symptoms_matched}
        for r in results
    ]

    prompt = (
        "You are an expert chemical-process engineer specialising in distillation column "
        "troubleshooting. Given the operating data and fault-diagnosis results below, "
        "provide a concise but expert AI commentary for EACH fault in 3–5 sentences. "
        "Focus on the most likely root cause given the specific numbers, and the single "
        "most impactful corrective step an operator should take first. "
        "Respond as a JSON object where each key is the fault name (e.g. FLOODING) and "
        "the value is your commentary string. No markdown, no preamble.\n\n"
        f"OPERATING CONDITIONS:\n{json.dumps(cond_dict, indent=2)}\n\n"
        f"SYMPTOMS REPORTED:\n{json.dumps(symptoms, indent=2)}\n\n"
        f"DETECTED FAULTS:\n{json.dumps(faults_summary, indent=2)}"
    )

    payload = {
        "contents": [{"parts": [{"text": prompt}]}],
        "generationConfig": {"temperature": 0.3, "maxOutputTokens": 1024},
    }

    try:
        print(f"      {DIM}→ Sending request...{R}", end="", flush=True)
        resp = requests.post(GEMINI_API_URL, json=payload, timeout=(GEMINI_TIMEOUT, GEMINI_TIMEOUT))
        print(f" {BGREEN}✓{R}")

        if resp.status_code != 200:
            print(f"      {BYELLOW}⚠ API status {resp.status_code}{R}")
            return {}

        print(f"      {DIM}→ Parsing response...{R}", end="", flush=True)
        raw = resp.json()
        text = raw["candidates"][0]["content"]["parts"][0]["text"].strip()
        # Strip possible markdown fences
        text = text.replace("```json", "").replace("```", "").strip()
        result = json.loads(text)
        print(f" {BGREEN}✓{R}")
        return result
    except requests.exceptions.Timeout:
        print(f" {BYELLOW}⚠ Timeout{R}")
        return {}
    except requests.exceptions.ConnectionError:
        print(f" {BYELLOW}⚠ Connection failed{R}")
        return {}
    except requests.exceptions.RequestException as e:
        print(f" {BYELLOW}⚠ Network error{R}")
        return {}
    except (KeyError, json.JSONDecodeError) as e:
        print(f" {BYELLOW}⚠ Invalid response{R}")
        return {}
    except Exception as e:
        print(f" {BYELLOW}⚠ {str(e)[:30]}{R}")
        return {}

# ═══════════════════════════ LANGGRAPH WORKFLOW ═════════════════════════════
def rule_based_analysis(state: DiagnosisState) -> DiagnosisState:
    """Node 1: Apply rule-based diagnosis"""
    print(f"  {DIM}[Node 1] Rule-based analysis...{R}", end="", flush=True)
    cond_obj = ColumnConditions(**state["conditions"])
    engine = RuleBasedDiagnostics()
    results = engine.diagnose(cond_obj, state["symptoms"])

    state["rule_based_results"] = [asdict(r) for r in results]
    state["processing_stage"] = "rule_analysis_complete"
    print(f" {BGREEN}✓{R}")
    return state

def ai_enhancement(state: DiagnosisState) -> DiagnosisState:
    """Node 2: Enhance with Gemini AI"""
    print(f"  {DIM}[Node 2] AI enhancement...{R}", end="", flush=True)

    if not state["rule_based_results"]:
        state["processing_stage"] = "no_faults_detected"
        state["final_diagnosis"] = []
        print(f" {BYELLOW}(no faults detected){R}")
        return state

    # Convert back to DiagnosisResult objects
    results = [DiagnosisResult(**r) for r in state["rule_based_results"]]

    # Get AI commentary with error handling
    ai_commentary = {}
    if GEMINI_ENABLED and results:
        print()
        print(f"    {BMAG}🤖 Calling Gemini {GEMINI_MODEL}...{R}")
        try:
            ai_commentary = gemini_enhance(state["conditions"], results, state["symptoms"])
            if ai_commentary:
                print(f"    {BGREEN}✓ AI commentary received for {len(ai_commentary)} fault(s){R}")
            else:
                print(f"    {BYELLOW}⚠ No AI commentary received (continuing with rule-based){R}")
        except Exception as e:
            print(f"    {BYELLOW}⚠ AI error: {str(e)[:50]} (continuing with rule-based){R}")
            ai_commentary = {}
    else:
        print(f" {BYELLOW}(AI disabled){R}")

    state["ai_commentary"] = ai_commentary

    # Enrich results with AI commentary
    enriched = []
    for r in results:
        r.ai_commentary = ai_commentary.get(r.problem, "")
        enriched.append(asdict(r))

    state["enriched_results"] = enriched
    state["processing_stage"] = "ai_enhancement_complete"
    return state

def finalize_diagnosis(state: DiagnosisState) -> DiagnosisState:
    """Node 3: Finalize and prepare output"""
    print(f"  {DIM}[Node 3] Finalizing...{R}", end="", flush=True)
    state["final_diagnosis"] = state["enriched_results"]
    state["processing_stage"] = "complete"
    print(f" {BGREEN}✓{R}")
    return state

def build_diagnosis_graph():
    """Build the LangGraph workflow"""
    workflow = StateGraph(DiagnosisState)

    # Add nodes
    workflow.add_node("rule_analysis", rule_based_analysis)
    workflow.add_node("ai_enhancement", ai_enhancement)
    workflow.add_node("finalize", finalize_diagnosis)

    # Add edges
    workflow.set_entry_point("rule_analysis")
    workflow.add_edge("rule_analysis", "ai_enhancement")
    workflow.add_edge("ai_enhancement", "finalize")
    workflow.add_edge("finalize", END)

    # Compile
    app = workflow.compile()
    return app

