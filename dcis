        ("Reflux Ratio (L/D)",  f"{cond.reflux_ratio}"               if cond.reflux_ratio else "—"),
        ("Reboiler Duty",       f"{cond.reboiler_duty} % of design"  if cond.reboiler_duty else "—"),
        ("Top Temperature",     f"{cond.top_temp} °C"                if cond.top_temp else "—"),
        ("Bottom Temperature",  f"{cond.bottom_temp} °C"             if cond.bottom_temp else "—"),
        ("Feed Temperature",    f"{cond.feed_temp} °C"               if cond.feed_temp else "—"),
        ("ΔP per Tray",         f"{cond.dp_tray} kPa"                if cond.dp_tray else "—"),
        ("Design ΔP per Tray",  f"{cond.design_dp_per_tray} kPa"     if cond.design_dp_per_tray else "—"),
        ("Foaming Observed",    "YES ⚠" if cond.foaming_observed else "No" if cond.foaming_observed is False else "—"),
        ("Vibrations",          "YES ⚠" if cond.vibration_observed else "No" if cond.vibration_observed is False else "—"),
        ("Product Off-Spec",    "YES ⚠" if cond.product_off_spec else "No" if cond.product_off_spec is False else "—"),
        ("Pressure Spike",      "YES ⚠" if cond.sudden_pressure_spike else "No" if cond.sudden_pressure_spike is False else "—"),
    ]
    # Two columns
    half = math.ceil(len(kvs) / 2)
    left, right = kvs[:half], kvs[half:]
    for i in range(max(len(left), len(right))):
        lk, lv = left[i] if i < len(left) else ("","")
        rk, rv = right[i] if i < len(right) else ("","")
        lc = BRED if "YES" in lv else BWHITE
        rc = BRED if "YES" in rv else BWHITE
        l_str = f"  {BCYAN}{lk:<22}{R} {lc}{lv:<18}{R}" if lk else " " * 44
        r_str = f"  {BCYAN}{rk:<22}{R} {rc}{rv}{R}"     if rk else ""
        print(l_str + r_str)
    print()

def print_score_gauge(score, max_score=100):
    pct = min(score, max_score)
    filled = int((pct / max_score) * 30)
    if pct >= 70:   color = BRED
    elif pct >= 45: color = BYELLOW
    else:           color = BCYAN
    bar = "█" * filled + "░" * (30 - filled)
    return f"  {color}[{bar}] Score: {pct}{R}"

