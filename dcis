                val = input(f"  {BBLACK}[{idx:2d}]{R} ").strip()
            parsed = parse_value(val, field_type, default_val)
            setattr(cond, field_name, parsed)

        # Symptoms
        print()
        if IS_COLAB:
            symptoms_input = input(f"  [19] ").strip()
