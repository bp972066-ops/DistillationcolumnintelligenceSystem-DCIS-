def typewrite(text, delay=0.018, color=""):
    for ch in text:
        sys.stdout.write(color + ch + R)
        sys.stdout.flush()
        time.sleep(delay)
    print()

def pause(s=0.6):
    time.sleep(s)

def center(text, width=W):
    return text.center(width)

def hline(char="═", color=BBLUE, width=W):
    print(color + char * width + R)

def thin_line(color=BBLACK):
    print(color + "─" * W + R)

def box_line(left="║", right="║", fill=" ", color=BBLUE, width=W):
    inner = fill * (width - 2)
    print(color + left + inner + right + R)

def spinner(msg, duration=1.4):
    frames = ["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"]
    end = time.time() + duration
    i = 0
    while time.time() < end:
        sys.stdout.write(f"\r  {BCYAN}{frames[i % len(frames)]}{R}  {BWHITE}{msg}{R}   ")
        sys.stdout.flush()
        time.sleep(0.08)
        i += 1
    sys.stdout.write("\r" + " " * 60 + "\r")

def progress_bar(label, steps=30, color=BCYAN, delay=0.03):
    print(f"  {BWHITE}{label}{R}")
    bar = ""
    for i in range(steps + 1):
        filled = int((i / steps) * 25)
        bar = "█" * filled + "░" * (25 - filled)
        pct = int((i / steps) * 100)
        try:
            sys.stdout.write(f"  {color}[{bar}]{R} {BYELLOW}{pct:3d}%{R}\r")
            sys.stdout.flush()
            time.sleep(delay)
        except (KeyboardInterrupt, SystemExit):
            print()
            raise
        except:
            # If stdout fails, just skip the visual update
            time.sleep(delay)
    print()

