def parse_value(val_str: str, field_type: str, default_val=None):
    """Parse input value based on field type"""
    val_str = val_str.strip()
    if val_str == "":
        return default_val  # Return default if provided, else None

    try:
        if field_type == "float":
            return float(val_str)
        elif field_type == "int":
            return int(val_str)
        elif field_type == "bool":
            v = val_str.lower()
            if v in ["y", "yes", "true", "1"]:
                return True
            elif v in ["n", "no", "false", "0"]:
                return False
            return default_val if default_val is not None else None
        else:
            return val_str
    except:
        return default_val if default_val is not None else None

