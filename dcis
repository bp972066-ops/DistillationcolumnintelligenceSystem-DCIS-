def save_report(results, cond, symptoms):
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    fn = f"DCIS_Report_{ts}.json"
    data = {
        "timestamp": ts,
        "conditions": {k: v for k, v in vars(cond).items() if v is not None},
        "symptoms_described": symptoms,
        "diagnosis": results,
    }
    with open(fn, "w") as f:
        json.dump(data, f, indent=2)

    if IS_COLAB:
        print(f"\n  Report saved: {fn}")
    else:
        print(f"\n  {BGREEN}📁  Report saved  →  {ULINE}{fn}{R}")
    return fn

